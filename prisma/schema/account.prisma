enum OngCategory {
  animais                    @map("Animais")
  meioAmbiente               @map("Meio Ambiente")
  educacao                   @map("Educação")
  saude                      @map("Saúde")
  direitosHumanos            @map("Direitos Humanos")
  combateAFome               @map("Combate à Fome")
  criancasEAdolescentes      @map("Crianças e Adolescentes")
  idosos                     @map("Idosos")
  pessoasComDeficiencia      @map("Pessoas com Deficiência")
  moradoresDeRua             @map("Moradores de Rua")
  igualdadeDeGenero          @map("Igualdade de Gênero")
  refugiadosEImigrantes      @map("Refugiados e Imigrantes")
  protecaoAnimal             @map("Proteção Animal")
  desenvolvimentoComunitario @map("Desenvolvimento Comunitário")
  culturaEArte               @map("Cultura e Arte")
  esporteEInclusao           @map("Esporte e Inclusão")
  voluntariadoEDoacoes       @map("Voluntariado e Doações")
  tecnologiaSocial           @map("Tecnologia Social")
  direitosDasMulheres        @map("Direitos das Mulheres")
  outros                     @map("Outros")
}

enum UserRoleEnum {
  super_admin
  admin
  editor
}

enum AccountStatus {
  active
  inactive
}

model Organization {
  id          String    @id @default(uuid())
  email       String    @unique
  updated_at  DateTime  @updatedAt
  created_at  DateTime  @default(now())
  deleted_at  DateTime?
  is_user_new Boolean   @default(true)

  account_status AccountStatus @default(inactive)

  page_content         Page?
  organization_profile OrganizationProfile?
  invite_tokens        InviteToken[]

  @@index([account_status])
  @@index([deleted_at])
  @@map("organizations")
}

model OrganizationProfile {
  id              String   @id @default(uuid())
  ong_id          String   @unique
  name            String
  slug            String   @unique
  logo            String
  updated_at      DateTime @updatedAt
  created_at      DateTime @default(now())
  phone           String
  ong_description String?
  design_template String   @default("primary")

  ong_type  OngCategory?
  addresses Address[]

  organization Organization @relation(fields: [ong_id], references: [id])

  @@index([ong_type])
  @@map("organizations_profiles")
}

model Address {
  id                      String    @id @default(uuid())
  street                  String?
  number                  String?
  complement              String?
  city                    String?
  state                   String?
  postal_code             String?
  organization_profile_id String
  updated_at              DateTime  @updatedAt
  created_at              DateTime  @default(now())
  deleted_at              DateTime?
  is_primary              Boolean   @default(false)

  organizationProfile OrganizationProfile @relation(fields: [organization_profile_id], references: [id])

  @@index([organization_profile_id])
  @@index([deleted_at])
  @@map("addresses")
}

model InviteToken {
  id              String    @id @default(uuid())
  token           String    @unique @default(uuid())
  email           String
  organization_id String
  expires_at      DateTime
  used_at         DateTime?
  created_at      DateTime  @default(now())
  cancelled_at    DateTime?

  organization Organization @relation(fields: [organization_id], references: [id])

  @@index([token])
  @@index([email])
  @@map("invite_tokens")
}
